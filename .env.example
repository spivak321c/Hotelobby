# Database
DATABASE_URL=postgres://user:pass@host:5432/hotel_lobby?sslmode=require

# Redis
REDIS_URL=redis://user:pass@host:6379/0

# JWT
JWT_SECRET=change-me-to-a-random-32-byte-hex-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Paystack (card payments)
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_SECRET=

# Crossmint (crypto payments)
CROSSMINT_API_KEY=sk_staging_xxx
CROSSMINT_PROJECT_ID=your-project-id
CROSSMINT_WEBHOOK_SECRET=
CROSSMINT_ENV=staging

# SMTP (Gmail for MVP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=Hotel Lobby <noreply@hotellobby.com>

# Cloudinary (room images)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# App
PORT=8000
APP_ENV=development
APP_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173
